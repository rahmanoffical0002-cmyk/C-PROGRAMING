#include <stdio.h>
int main()
{
    int grade;
    if (grade >= 90)
    {
        printf("Grade : A");
    }
    else if(grade >=70 && grade<90){
        printf("Grade : B");
    }
    else if(grade >=50 && grade<70){
        printf("Grade : c");
    }
    else{
        printf("Grade : F");
    }

    return 0;
}